#!/usr/bin/env python3
"""meta-toolkit CLI — metadata extraction and forensic analysis."""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

# Ensure package root is on sys.path when invoked as ./meta_extract
_ROOT = Path(__file__).resolve().parent
if str(_ROOT) not in sys.path:
    sys.path.insert(0, str(_ROOT))

from core.orchestrator import analyze_file
from core.batch_analyzer import analyze_directory

from utils.exporter import (
    export_json,
    export_txt,
    export_to_file,
)

from utils.summary_exporter import export_summary
from utils.ui_rich import render_report


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="meta_extract",
        description="Extract and forensically analyze file metadata.",
    )

    group = parser.add_mutually_exclusive_group(required=True)

    group.add_argument(
        "-f",
        "--file",
        help="Analyze a single file.",
    )

    group.add_argument(
        "-d",
        "--directory",
        help="Analyze all files in a directory recursively.",
    )

    parser.add_argument(
        "--json",
        action="store_true",
        help="Emit report as JSON.",
    )
    parser.add_argument(
        "--txt",
        action="store_true",
        help="Emit report as plain text.",
    )

    parser.add_argument(
        "-o",
        "--output",
        help=(
            "Output report path (single-file mode) "
            "or output directory (batch mode)."
        ),
    )

    parser.add_argument(
        "--format",
        choices=["json", "txt"],
        help="Output format.",
    )

    parser.add_argument(
        "--workers",
        type=int,
        default=8,
        help="Number of concurrent workers in batch mode.",
    )
    parser.add_argument(
    "--ai",
    action="store_true",
    help="Generate AI-assisted analysis",
    )

    return parser


def run_batch(args) -> int:

    if not args.output:
        print(
            "error: batch mode requires --output",
            file=sys.stderr,
        )
        return 1

    fmt = args.format or "txt"

    summary = analyze_directory(
        input_dir=args.directory,
        output_dir=args.output,
        workers=args.workers,
        fmt=fmt,
        enable_ai=args.ai,
    )

    export_summary(
        summary,
        Path(args.output),
    )

    print()
    print("Batch analysis complete")
    print(f"Files discovered : {summary['total_files']}")
    print(f"Successful       : {summary['successful']}")
    print(f"Failed           : {summary['failed']}")
    print(f"High risk        : {summary['high_risk']}")
    print(f"Medium risk      : {summary['medium_risk']}")
    print(f"Low risk         : {summary['low_risk']}")
    print()
    print(f"Reports written to: {args.output}")

    return 0


def run_single_file(args) -> int:

    target = Path(args.file)

    try:
        report = analyze_file(target, enable_ai=args.ai)

    except FileNotFoundError as exc:
        print(
            f"error: {exc}",
            file=sys.stderr,
        )
        return 1

    except OSError as exc:
        print(
            f"error: cannot read file: {exc}",
            file=sys.stderr,
        )
        return 1

    fmt = "json" if args.json else args.format

    if args.output and not fmt:
        suffix = (
            Path(args.output)
            .suffix
            .lower()
            .lstrip(".")
        )

        fmt = (
            suffix
            if suffix in {"json", "txt"}
            else "json"
        )

    if not fmt:
        render_report(report)
        return 0

    if args.output:

        render_report(report)

        export_to_file(
            report,
            Path(args.output),
            fmt=fmt,
        )

    elif fmt == "json":
        export_json(report)

    elif fmt == "txt":
        export_txt(report)
    
    elif not fmt:
        render_report(report)

    else:
        render_report(report)

    return 0


def main(argv: list[str] | None = None) -> int:

    args = build_parser().parse_args(argv)

    if args.directory:
        return run_batch(args)

    return run_single_file(args)


if __name__ == "__main__":
        raise SystemExit(main())