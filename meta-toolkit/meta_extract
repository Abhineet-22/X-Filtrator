#!/usr/bin/env python3
"""meta-toolkit CLI — metadata extraction and forensic analysis."""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

# Ensure package root is on sys.path when invoked as ./meta_extract
_ROOT = Path(__file__).resolve().parent
if str(_ROOT) not in sys.path:
    sys.path.insert(0, str(_ROOT))

from core.orchestrator import analyze_file
from utils.exporter import export_csv, export_json, export_txt, export_to_file
from utils.ui_rich import render_report


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="meta_extract",
        description="Extract and forensically analyze file metadata.",
    )
    parser.add_argument(
        "-f",
        "--file",
        required=True,
        help="Path to the target file for analysis.",
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="Emit the full report as JSON instead of a rich terminal layout.",
    )
    parser.add_argument(
        "-o",
        "--output",
        help="Path to write the exported report file. If omitted, output is sent to stdout.",
    )
    parser.add_argument(
        "--format",
        choices=["json", "csv", "txt"],
        help="Select export format when writing output to a file or stdout.",
    )
    return parser


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    target = Path(args.file)

    try:
        report = analyze_file(target)
    except FileNotFoundError as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1
    except OSError as exc:
        print(f"error: cannot read file: {exc}", file=sys.stderr)
        return 1

    # Determine output format
    fmt = "json" if args.json else args.format
    if args.output and not fmt:
        suffix = Path(args.output).suffix.lower().lstrip('.')
        fmt = suffix if suffix in {"json", "csv", "txt"} else "json"
    if not fmt:
        fmt = "json"

    if args.output:
        output_path = Path(args.output)
        export_to_file(report, output_path, fmt=fmt)
    else:
        if fmt == "json":
            export_json(report)
        elif fmt == "csv":
            export_csv(report)
        elif fmt == "txt":
            export_txt(report)
        else:
            export_json(report)

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
